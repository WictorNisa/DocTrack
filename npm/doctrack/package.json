{
  "name": "doctrack",
  "version": "0.1.0",
  "description": "Keep documentation in sync with code changes automatically",
  "license": "Apache-2.0",
  "author": "DocTrack contributors",
  "homepage": "https://github.com/WictorNisa/DocTrack",
  "bugs": {
